// Vehicle gate.
// 0x0066BB48 = current car pointer. Test high halfword at 0x0066BB4A.
// If nonzero: install remapper hook jumps.
// If zero: restore original game instructions.

// IN VEHICLE: if 16-bit value at 0x0066BB4A != 0, run next 2 patch commands.
patch=1,EE,D066BB4A,extended,02100000
patch=1,EE,205325CC,extended,0803F414
patch=1,EE,20532674,extended,0803F417

// ON FOOT: if 16-bit value at 0x0066BB4A == 0, run next 2 patch commands.
patch=1,EE,D066BB4A,extended,02000000
patch=1,EE,205325CC,extended,24030070
patch=1,EE,20532674,extended,03E00008
